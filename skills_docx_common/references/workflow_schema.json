{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Feature Workflow",
  "type": "object",
  "additionalProperties": true,
  "required": [],
  "anyOf": [
    {
      "required": [
        "basic_flow"
      ]
    },
    {
      "required": [
        "nodes",
        "edges"
      ]
    }
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string"
    },
    "title": {
      "type": "string",
      "description": "Feature or diagram title. Used as name when name is absent."
    },
    "diagram_title": {
      "type": "string",
      "description": "Draw.io diagram title. Falls back to title/name."
    },
    "section_number": {
      "type": "string",
      "description": "Base section number used in generated DOCX headings, for example 4.1.2.3.2"
    },
    "purpose": {
      "type": "string"
    },
    "actor": {
      "type": "string"
    },
    "source_image": {
      "type": "string"
    },
    "lanes": {
      "$ref": "#/definitions/lanes"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/diagram_node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/diagram_edge"
      }
    },
    "inputs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/input"
      }
    },
    "buttons": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/button"
      }
    },
    "tables": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/table"
      }
    },
    "basic_flow": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/definitions/flow_step"
      }
    },
    "alternative_flow": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/flow_step"
      }
    },
    "alternative_flows": {
      "type": "array",
      "description": "Multiple alternative/exception flows. Each item renders as one separate DOCX table.",
      "items": {
        "$ref": "#/definitions/flow_group"
      }
    },
    "validation_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "business_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "api_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error_scenarios": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "definitions": {
    "lanes": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "user": {
          "type": "string"
        },
        "system": {
          "type": "string"
        }
      }
    },
    "diagram_node": {
      "type": "object",
      "required": [
        "id",
        "label"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "start",
            "process",
            "decision",
            "end",
            "task"
          ]
        },
        "shape": {
          "type": "string",
          "enum": [
            "oval",
            "ellipse",
            "rectangle",
            "diamond",
            "rhombus"
          ]
        },
        "label": {
          "type": "string"
        },
        "lane": {
          "type": "string"
        },
        "x": {
          "type": "number"
        },
        "y": {
          "type": "number"
        },
        "width": {
          "type": "number"
        },
        "height": {
          "type": "number"
        }
      }
    },
    "diagram_edge": {
      "type": "object",
      "required": [
        "from",
        "to"
      ],
      "additionalProperties": true,
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "input": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "validation": {
          "type": "string"
        }
      }
    },
    "button": {
      "type": "object",
      "required": [
        "label"
      ],
      "additionalProperties": true,
      "properties": {
        "label": {
          "type": "string"
        },
        "action": {
          "type": "string"
        }
      }
    },
    "table": {
      "type": "object",
      "required": [
        "name"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "flow_step": {
      "type": "object",
      "required": [
        "actor",
        "system"
      ],
      "additionalProperties": true,
      "properties": {
        "actor": {
          "type": "string"
        },
        "system": {
          "type": "string"
        },
        "crud": {
          "type": "string"
        }
      }
    },
    "flow_group": {
      "type": "object",
      "required": [
        "steps"
      ],
      "additionalProperties": true,
      "properties": {
        "name": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/flow_step"
          }
        }
      }
    }
  }
}
